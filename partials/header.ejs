<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="/socket.io/socket.io.js"></script>

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm navbar-live">
  <div class="container navbar-live-shell">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <i class="bi bi-mug-hot fs-2 text-warning"></i>
      <div>
        <div class="fw-bold">Kundu Cafe</div>
        <small class="text-muted d-block">Coffee, Comfort, Community</small>
      </div>
    </a>

    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navLinks" aria-controls="navLinks" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navLinks">
      <div class="navbar-nav ms-auto align-items-lg-center gap-2 navbar-menu-live">
        <% if (user) { %>
          <% if (user.role === 'admin') { %>
          <% } else { %>
            <a class="nav-link d-flex align-items-center gap-1" href="/"><i class="bi bi-house-fill"></i>Home</a>
            <a class="nav-link d-flex align-items-center gap-1" href="/products"><i class="bi bi-box-seam"></i>Products</a>
            <a class="nav-link d-flex align-items-center gap-1 position-relative" href="/cart">
              <i class="bi bi-cart-fill"></i>Cart
              <span id="cartCountBadge" class="badge rounded-pill bg-danger ms-1 d-none">0</span>
            </a>
            <a class="nav-link d-flex align-items-center gap-1" href="/orders"><i class="bi bi-receipt-cutoff"></i>Orders</a>
            <a class="nav-link d-flex align-items-center gap-1" href="/wallet"><i class="bi bi-wallet2"></i>Wallet</a>
          <% } %>
          <div class="dropdown profile-dropdown-shell">
            <button
              class="nav-link profile-dropdown-toggle"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              <span class="profile-mini-avatar"><%= (user.username || 'U').charAt(0).toUpperCase() %></span>
              <span class="user-badge user-badge-dropdown">
                <strong><%= user.username %></strong>
                <small><%= user.role === 'admin' ? 'Admin' : 'Profile' %></small>
              </span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end profile-dropdown-menu">
              <li class="profile-dropdown-header">
                <strong><%= user.username %></strong>
                <small><%= user.email %></small>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item" href="/profile">
                  <i class="bi bi-person-circle"></i>
                  <span><%= user.role === 'admin' ? 'Admin Profile' : 'My Profile' %></span>
                </a>
              </li>
              <% if (user.role === 'admin') { %>
                <li>
                  <a class="dropdown-item" href="/admin">
                    <i class="bi bi-speedometer2"></i>
                    <span>Admin Dashboard</span>
                  </a>
                </li>
              <% } else { %>
                <li>
                  <a class="dropdown-item" href="/orders">
                    <i class="bi bi-receipt-cutoff"></i>
                    <span>Orders</span>
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="/wallet">
                    <i class="bi bi-wallet2"></i>
                    <span>Wallet</span>
                  </a>
                </li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item profile-logout-link" href="/auth/logout">
                  <i class="bi bi-box-arrow-right"></i>
                  <span>Logout</span>
                </a>
              </li>
            </ul>
          </div>
        <% } else { %>
          <a class="nav-link d-flex align-items-center gap-1" href="/"><i class="bi bi-house-fill"></i>Home</a>
          <a class="nav-link d-flex align-items-center gap-1" href="/products"><i class="bi bi-box-seam"></i>Products</a>
          <a class="nav-link d-flex align-items-center gap-1 position-relative" href="/cart">
            <i class="bi bi-cart-fill"></i>Cart
            <span id="cartCountBadge" class="badge rounded-pill bg-danger ms-1 d-none">0</span>
          </a>
          <a class="nav-link d-flex align-items-center gap-1" href="/auth/login"><i class="bi bi-person-circle"></i>Login</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
