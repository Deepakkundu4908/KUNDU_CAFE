<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kundu Cafe - Home</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container mt-5">
    <section class="hero-section mb-5">
      <div class="row align-items-center">
        <div class="col-lg-6 mb-4 mb-lg-0">
          <span class="badge bg-warning text-dark badge-pill mb-2">Fresh Daily</span>
          <h1 class="display-5 fw-bold">Kundu Cafe</h1>
          <p class="lead text-muted">Colorful coffee rituals, handcrafted bites, and a community that feels like home. Drop by for a vibrantly warm experience.</p>

          <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-warning btn-lg fw-semibold shadow-sm" href="/products"><i class="bi bi-mug-hot me-2"></i>Browse Menu</a>
            <a class="btn btn-outline-dark btn-lg fw-semibold d-flex align-items-center gap-2" href="/cart"><i class="bi bi-cart"></i>View Cart</a>
            <% if (user) { %>
              <a class="btn btn-outline-light btn-lg fw-semibold d-flex align-items-center gap-2" href="/orders"><i class="bi bi-receipt-cutoff"></i>My Orders</a>
            <% } else { %>
              <a class="btn btn-outline-light btn-lg fw-semibold d-flex align-items-center gap-2" href="/auth/login"><i class="bi bi-person-circle"></i>Login</a>
            <% } %>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="bg-white p-4 rounded-4 shadow feature-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <div>
                <h5 class="mb-1">Today&apos;s vibes</h5>
                <p class="small text-muted mb-0">Sunrise blends + twilight pastries</p>
              </div>
              <span class="text-warning display-6"><i class="bi bi-sunrise"></i></span>
            </div>
            <div class="row text-center text-muted">
              <div class="col-6 border-end border-muted">
                <p class="mb-1">Baristas</p>
                <strong>5</strong>
              </div>
              <div class="col-6">
                <p class="mb-1">Roasts</p>
                <strong>12</strong>
              </div>
            </div>

            <% if (user) { %>
              <div class="feature-welcome mt-4">
                <span class="welcome-pill"><i class="bi bi-person-heart me-2"></i>Welcome back, <strong><%= user.username %></strong></span>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-5">
      <div class="row align-items-center">
        <div class="col-md-6 order-md-2">
          <img src="/images/kundu-cafe-logo.svg" alt="Kundu Cafe" class="img-fluid rounded-4 shadow-lg live-logo-image">
        </div>
        <div class="col-md-6 order-md-1">
          <h3>Why Kundu?</h3>
          <p class="text-muted">We blend global inspiration with local ingredients, so every cup sings with color, warmth, and joy.</p>
          <ul class="list-unstyled text-muted">
            <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i>Seasonal latte art painted by hand</li>
            <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i>Ingredient-forward bites sourced from local farms</li>
            <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i>Community events every Saturday evening</li>
          </ul>
        </div>
      </div>
    </section>

    <% if (user) { %>
      <section class="mb-5">
        <div class="menu-panel live-panel">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h3 class="page-subtitle mb-0"><i class="bi bi-stars me-2"></i>Your Frequent Orders</h3>
            <a href="/products" class="btn btn-sm btn-warning">See full menu</a>
          </div>
          <div id="frequentOrdersContainer" class="frequent-orders-container">
            <p class="text-muted mb-0">Loading your favorite items...</p>
          </div>
        </div>
      </section>
    <% } %>
  </div>

  <% if (user) { %>
  <script>
  async function loadFrequentOrders() {
    try {
      const response = await fetch('/products/frequent');
      const items = await response.json();
      const container = document.getElementById('frequentOrdersContainer');

      if (!items || items.length === 0) {
        container.innerHTML = '<p class="text-muted mb-0">Browse and order to build your favorites.</p>';
        return;
      }

      container.innerHTML = items.map(item => `
        <div class="frequent-item-card text-center">
          <div class="tile-icon mb-2">
            ${item.category === 'Breakfast' ? '<i class="bi bi-sunrise-fill"></i>' :
              item.category === 'Lunch' ? '<i class="bi bi-egg-fried"></i>' :
              item.category === 'Snacks' ? '<i class="bi bi-cake2-fill"></i>' : '<i class="bi bi-cup-hot-fill"></i>'}
          </div>
          <h6 class="mb-1">${item.name}</h6>
          <p class="text-muted small mb-2">₹${item.price}</p>
          <button class="btn btn-sm btn-success" onclick="quickAddToCart(${item.id}, '${item.name}')">
            <i class="bi bi-bag-plus-fill me-1"></i>Add to Cart
          </button>
        </div>
      `).join('');
    } catch (error) {
      console.error('Error loading frequent orders:', error);
    }
  }

  function quickAddToCart(itemId, itemName) {
    fetch('/cart/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ itemId, quantity: 1 })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        alert(`${itemName} added to cart!`);
        if (typeof window.updateCartBadge === 'function') {
          window.updateCartBadge((Number(document.getElementById('cartCountBadge')?.textContent) || 0) + 1);
        }
      }
    })
    .catch(error => console.error('Error:', error));
  }

  document.addEventListener('DOMContentLoaded', loadFrequentOrders);
  </script>
  <% } %>

  <%- include('../partials/footer') %>
</body>
</html>
