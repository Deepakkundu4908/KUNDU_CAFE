<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up - Kundu Cafe</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page auth-page-signup">
  <main class="auth-shell auth-shell-signup">
    <section class="auth-card auth-card-form auth-card-wide">
      <div class="auth-card-inner">
        <div class="auth-topbar">
          <a href="/" class="auth-brand">
            <span class="auth-brand-mark">KC</span>
            <span>
              <strong>Kundu Cafe</strong>
              <small>Fresh perks start here</small>
            </span>
          </a>
          <span class="auth-status-pill">Secure signup</span>
        </div>

        <div class="auth-heading">
          <p class="auth-eyebrow">Create your account</p>
          <h1>Join the cafe community</h1>
          <p class="auth-subtitle">Set up your account in a minute and start ordering right away.</p>
        </div>

        <% if (typeof message !== 'undefined' && message) { %>
          <div class="error-message auth-message"><%= message %></div>
        <% } %>

        <form method="POST" action="/auth/signup" id="signup-form" class="auth-form auth-form-grid">
          <div class="form-group auth-field auth-field-full">
            <label for="username">Full Name</label>
            <input type="text" id="username" name="username" autocomplete="name" placeholder="Aarav Sharma" required>
          </div>

          <div class="form-group auth-field">
            <label for="email">Personal Email</label>
            <input type="email" id="email" name="email" autocomplete="email" placeholder="you@example.com" required>
          </div>

          <div class="form-group auth-field">
            <label for="password">Password</label>
            <div class="auth-input-row">
              <input type="password" id="password" name="password" autocomplete="new-password" placeholder="At least 6 characters" required>
              <button type="button" class="auth-toggle" data-target="password">Show</button>
            </div>
          </div>

          <div class="form-group auth-field auth-field-full">
            <label for="passwordConfirm">Confirm Password</label>
            <div class="auth-input-row">
              <input type="password" id="passwordConfirm" name="passwordConfirm" autocomplete="new-password" placeholder="Repeat your password" required>
              <button type="button" class="auth-toggle" data-target="passwordConfirm">Show</button>
            </div>
          </div>

          <div class="auth-field-full">
            <div class="auth-meter">
              <div class="auth-meter-bar" id="strength-bar"></div>
            </div>
            <p class="auth-dynamic-hint" id="dynamic-hint">We'll keep you signed in on trusted devices.</p>
          </div>

          <button type="submit" class="btn btn-primary auth-submit auth-field-full">Create account</button>
        </form>

        <div class="auth-inline-links auth-inline-links-centered">
          <span>Already have an account? <a href="/auth/login">Login here</a></span>
        </div>

        <div class="auth-footer-meta">
          <span id="status-label">Enter a valid email to keep things flowing.</span>
          <span id="status-timer">Ready</span>
        </div>
      </div>
    </section>

    <aside class="auth-card auth-card-panel">
      <p class="auth-panel-kicker">Live cues</p>
      <h2>Interactive signup</h2>
      <p class="auth-panel-copy" id="tip-text">Every pause gets a fresh tip just for you.</p>

      <ul class="auth-benefits">
        <li>Password strength updates in real time</li>
        <li>Email validation keeps registration clean</li>
        <li>Show or hide passwords to catch typos early</li>
      </ul>

      <div class="auth-tip-box">
        <span>Fresh onboarding tip</span>
        <p id="dynamic-tip">Use the email address you want for future logins.</p>
      </div>
    </aside>
  </main>

  <script>
    (function () {
      const email = document.getElementById('email');
      const password = document.getElementById('password');
      const passwordConfirm = document.getElementById('passwordConfirm');
      const strengthBar = document.getElementById('strength-bar');
      const dynamicHint = document.getElementById('dynamic-hint');
      const statusLabel = document.getElementById('status-label');
      const statusTimer = document.getElementById('status-timer');
      const dynamicTip = document.getElementById('dynamic-tip');
      const tipText = document.getElementById('tip-text');
      const toggles = document.querySelectorAll('.auth-toggle');
      const tips = [
        'Use the same full name you want to see on your orders.',
        'A strong password plus your email makes account recovery easier.',
        'Use an email address you can access easily before you submit the form.'
      ];
      let tipIndex = 0;
      let typingTimer = null;

      const setStrength = () => {
        const value = password.value.trim();
        let percent = 8;
        let text = 'We\\'ll keep you signed in on trusted devices.';

        if (!value) {
          percent = 8;
        } else if (value.length < 6) {
          percent = 26;
          text = 'Password is still short. Add more characters to pass validation smoothly.';
        } else if (value.length < 10) {
          percent = 64;
          text = 'Nice start. A longer password makes your account harder to crack.';
        } else {
          percent = 100;
          text = 'Strong length detected. Your account setup looks safer now.';
        }

        if (passwordConfirm.value) {
          if (passwordConfirm.value === value) {
            text = 'Passwords match. You are ready to submit.';
          } else {
            text = 'Passwords do not match yet. One more quick check.';
          }
        }

        strengthBar.style.width = percent + '%';
        dynamicHint.textContent = text;
      };

      const updateEmailStatus = () => {
        const value = email.value.trim();
        if (!value) {
          statusLabel.textContent = 'Enter a valid email to keep things flowing.';
          return;
        }

        const isValidEmail = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(value);
        statusLabel.textContent = isValidEmail
          ? 'Email format looks correct.'
          : 'Email format needs a quick check.';
      };

      const bumpTip = () => {
        tipIndex = (tipIndex + 1) % tips.length;
        dynamicTip.innerHTML = tips[tipIndex];
        tipText.textContent = 'Fresh tip loaded while you pause.';
      };

      const resetTimer = () => {
        statusTimer.textContent = 'Typing...';
        clearTimeout(typingTimer);
        typingTimer = setTimeout(function () {
          statusTimer.textContent = 'Ready';
          bumpTip();
        }, 900);
      };

      email.addEventListener('input', function () {
        updateEmailStatus();
        resetTimer();
      });

      password.addEventListener('input', function () {
        setStrength();
        resetTimer();
      });

      passwordConfirm.addEventListener('input', function () {
        setStrength();
        resetTimer();
      });

      toggles.forEach(function (button) {
        button.addEventListener('click', function () {
          const target = document.getElementById(button.getAttribute('data-target'));
          const isPassword = target.type === 'password';
          target.type = isPassword ? 'text' : 'password';
          button.textContent = isPassword ? 'Hide' : 'Show';
        });
      });

      setStrength();
      updateEmailStatus();
    })();
  </script>
</body>
</html>
