<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Kundu Cafe</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page auth-page-login">
  <main class="auth-shell auth-shell-login">
    <section class="auth-card auth-card-form">
      <div class="auth-card-inner">
        <div class="auth-topbar">
          <a href="/" class="auth-brand">
            <span class="auth-brand-mark">KC</span>
            <span>
              <strong>Kundu Cafe</strong>
              <small>Coffee, comfort, community</small>
            </span>
          </a>
          <span class="auth-status-pill">Live security</span>
        </div>

        <div class="auth-heading">
          <p class="auth-eyebrow">Welcome back</p>
          <h1>Login to your account</h1>
          <p class="auth-subtitle">Sign in with your email and password to get back to your next order.</p>
        </div>

        <% if (typeof message !== 'undefined' && message) { %>
          <div class="error-message auth-message"><%= message %></div>
        <% } %>

        <form method="POST" action="/auth/login" id="login-form" class="auth-form">
          <div class="form-group auth-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" autocomplete="username" placeholder="you@example.com" required>
          </div>

          <div class="form-group auth-field">
            <label for="password">Password</label>
            <div class="auth-input-row">
              <input type="password" id="password" name="password" autocomplete="current-password" placeholder="Enter your password" required>
              <button type="button" class="auth-toggle" data-target="password">Show</button>
            </div>
          </div>

          <div class="auth-meter">
            <div class="auth-meter-bar" id="strength-bar"></div>
          </div>
          <p class="auth-dynamic-hint" id="dynamic-hint">Keep your credentials safe, we've got the rest covered.</p>

          <button type="submit" class="btn btn-primary auth-submit">Login</button>

          <div class="auth-inline-links">
            <a href="/auth/forgot-password">Forgot password?</a>
            <span>New here? <a href="/auth/signup">Create account</a></span>
          </div>
        </form>

        <div class="auth-footer-meta">
          <span id="status-label">Enter your email to check format.</span>
          <span id="status-timer">Ready</span>
        </div>
      </div>
    </section>

    <aside class="auth-card auth-card-panel">
      <p class="auth-panel-kicker">Live cues</p>
      <h2>Interactive login</h2>
      <p class="auth-panel-copy" id="tip-text">We refresh tips each time you pause.</p>

      <ul class="auth-benefits">
        <li>Progress bar reacts as you type</li>
        <li>Email validation keeps sign-in clean</li>
        <li>Password visibility toggles with one tap</li>
      </ul>

      <div class="auth-tip-box">
        <span>Next mini tip</span>
        <p id="dynamic-tip">Use your registered email, or the admin email if you are signing in as admin.</p>
      </div>
    </aside>
  </main>

  <script>
    (function () {
      const email = document.getElementById('email');
      const password = document.getElementById('password');
      const strengthBar = document.getElementById('strength-bar');
      const dynamicHint = document.getElementById('dynamic-hint');
      const statusLabel = document.getElementById('status-label');
      const statusTimer = document.getElementById('status-timer');
      const dynamicTip = document.getElementById('dynamic-tip');
      const tipText = document.getElementById('tip-text');
      const toggleButton = document.querySelector('[data-target="password"]');
      const tips = [
        'Use the same email you signed up with to avoid extra retries.',
        'Longer passwords are easier to protect and harder to guess.',
        'Admin login uses the same form, just enter the admin email and password.'
      ];
      let tipIndex = 0;
      let typingTimer = null;

      const setStrength = () => {
        const value = password.value.trim();
        let percent = 8;
        let text = 'Waiting for password input.';

        if (!value) {
          percent = 8;
          text = 'Keep your credentials safe, we\\'ve got the rest covered.';
        } else if (value.length < 6) {
          percent = 28;
          text = 'Short password detected. Add more characters for a safer login.';
        } else if (value.length < 10) {
          percent = 62;
          text = 'Nice. A slightly longer password gives you a stronger barrier.';
        } else {
          percent = 100;
          text = 'Strong length detected. You are ready to sign in.';
        }

        strengthBar.style.width = percent + '%';
        dynamicHint.textContent = text;
      };

      const updateEmailStatus = () => {
        const value = email.value.trim();
        if (!value) {
          statusLabel.textContent = 'Enter your email to check format.';
          return;
        }

        const isValid = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(value);
        statusLabel.textContent = isValid ? 'Email format looks good.' : 'Email format needs a quick check.';
      };

      const bumpTip = () => {
        tipIndex = (tipIndex + 1) % tips.length;
        dynamicTip.textContent = tips[tipIndex];
        tipText.textContent = 'Fresh tip loaded while you pause.';
      };

      const resetTimer = () => {
        statusTimer.textContent = 'Typing...';
        clearTimeout(typingTimer);
        typingTimer = setTimeout(function () {
          statusTimer.textContent = 'Ready';
          bumpTip();
        }, 900);
      };

      email.addEventListener('input', function () {
        updateEmailStatus();
        resetTimer();
      });

      password.addEventListener('input', function () {
        setStrength();
        resetTimer();
      });

      toggleButton.addEventListener('click', function () {
        const isPassword = password.type === 'password';
        password.type = isPassword ? 'text' : 'password';
        toggleButton.textContent = isPassword ? 'Hide' : 'Show';
      });

      setStrength();
      updateEmailStatus();
    })();
  </script>
</body>
</html>
